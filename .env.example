# === Entity Configuration ===

# Port for the entity server
PORT=3402

# Port for the facilitator service
FACILITATOR_PORT=4020

# === Fast Wallet ===
# Path to Fast wallet keyfile (default: ~/.fast/keys/default.json)
# FAST_KEYFILE=default

# Network: "mainnet" or "testnet"
FAST_NETWORK=mainnet

# === Payment Pricing ===
# Price per summarize call in USD
PRICE_PER_CALL=$0.01

# === Facilitator ===
# EVM private key for the facilitator (needed for EVM settlement only)
# Not required for Fast-only payments
# FACILITATOR_EVM_KEY=0x...

# Facilitator URL (default: http://localhost:4020)
FACILITATOR_URL=http://localhost:4020

# === Optional: LLM API for better summaries ===
# If not set, uses built-in extractive summarizer (free, decent quality)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
